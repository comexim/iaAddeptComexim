# Application
APP_NAME=agente-comexim
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# SQL Server
SQL_SERVER_HOST=seu_servidor_sql
SQL_SERVER_PORT=6776
SQL_SERVER_DATABASE=Protheus
SQL_SERVER_USER=seu_usuario
SQL_SERVER_PASSWORD=sua_senha
SQL_SERVER_DRIVER=SQL Server

# Redis (Redis Cloud)
REDIS_HOST=seu_redis_host
REDIS_PORT=18430
REDIS_PASSWORD=sua_senha_redis
REDIS_DB=0

## Protheus API (Autenticação)
PROTHEUS_API_URL=http://seu_servidor:7000
PROTHEUS_API_TOKEN_ENDPOINT=/iaProtheus/getToken

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua_evolution_api
EVOLUTION_API_TOKEN=seu_token
EVOLUTION_INSTANCE_NAME=sua_instancia

# LLM Provider (openai ou anthropic)
LLM_PROVIDER=openai
OPENAI_API_KEY=sua_chave_openai
ANTHROPIC_API_KEY=

# AI Configuration
AI_MODEL=gpt-4o
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4000
FORMATTER_MODEL=gpt-4o-mini
FORMATTER_TEMPERATURE=0

# Memory Configuration
REDIS_MEMORY_TTL=7200
REDIS_MEMORY_WINDOW=10

# Anti-Flood Configuration
ANTI_FLOOD_WAIT_SECONDS=20
MESSAGE_DELAY_SECONDS=3

# Supabase (Preference Learning System)
SUPABASE_URL=https://sua_url.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role

# Features
ENABLE_AUDIO_TRANSCRIPTION=true
ENABLE_RESPONSE_FORMATTER=false
ENABLE_IMAGE_ANALYSIS=false
ENABLE_PREFERENCE_LEARNING=true
